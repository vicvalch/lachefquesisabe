# Copia este archivo a .env.local y completa con los valores de tu proyecto de Supabase
# (Project Settings > API en https://app.supabase.com).

NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu-anon-key

# Opcional: número de WhatsApp del negocio para los CTA públicos (con o sin
# código de país). Si se deja vacío, los botones de WhatsApp del sitio
# público redirigen al formulario de contacto en vez de abrir un chat.
NEXT_PUBLIC_WHATSAPP_NUMBER=

# Opcionales: personalizan la sección Thermomix de la landing. Si se dejan
# vacíos, se muestran placeholders en su lugar.
NEXT_PUBLIC_THERMOMIX_IMAGE_URL=
NEXT_PUBLIC_THERMOMIX_VIDEO_URL=
NEXT_PUBLIC_THERMOMIX_OFFICIAL_URL=
